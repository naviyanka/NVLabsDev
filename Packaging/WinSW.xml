<service>
  <id>NexusFrontend</id>
  <name>Nexus Frontend</name>
  <description>Nexus Frontend UI running on Node.js</description>
  <executable>%BASE%\node.exe</executable>
  <arguments>dist/server/server.js</arguments>
  <env name="PORT" value="5011"/>
  <log mode="roll"></log>
  <onfailure action="restart" delay="10 sec"/>
  <!-- Keep the Node.js process working dir aligned -->
  <workingdirectory>%BASE%</workingdirectory>
</service>
